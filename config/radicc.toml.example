# vim: ft=toml

base_dir = "$HOME/Radiko" # 全番組共通の保存先。未設定時は RADICC_DIR、未設定時には ./ を使用

["宮本佳林の雑談ラジオ"] # *1
id = "karin-zatsudan" # unique id (optional)
title = "宮本佳林の雑談ラジオ" # title (= section name if omitted)
station = "JORF"
date_offset = 1 # file date offset (days) for filename only。--url では未使用

["Aぇ! group小島健のラジキング"] # *1
id = "koji-radiking"
title = "Aぇ! group小島健のラジキング"
station = "FMO"
dir = "Aぇ! group小島健のラジキング" # base_dir 配下のサブディレクトリ名
filename = "小島健のラジキング"      # 基本は <title>-YYYYMMDD.m4a が自動
img = "https://..."           # カバー画像URL（取得できない場合のみ使用）
pfm = "小島健"           # パーソナリティ（取得できない場合のみ使用）
